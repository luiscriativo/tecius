{
  "name": "tecius",
  "version": "1.2.1",
  "description": "Tecius — Sistema pessoal de timelines visuais",
  "main": "./out/main/index.js",
  "homepage": ".",
  "author": {
    "name": "luiscriativo",
    "email": "luiscriativo@github.com"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "protect": "node scripts/protect.js",
    "protect:no-bytecode": "node scripts/protect.js --no-bytecode",
    "build:win": "electron-vite build && electron-builder --win",
    "build:win:x64": "electron-vite build && electron-builder --win --x64",
    "build:win:arm64": "electron-vite build && electron-builder --win --arm64",
    "build:win:protected": "electron-vite build && node scripts/protect.js && electron-builder --win",
    "build:win:x64:protected": "electron-vite build && node scripts/protect.js && electron-builder --win --x64",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:protected": "electron-vite build && node scripts/protect.js && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:linux:protected": "electron-vite build && node scripts/protect.js && electron-builder --linux",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@radix-ui/react-slot": "^1.2.4",
    "bytenode": "^1.5.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/flexsearch": "^0.7.6",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
